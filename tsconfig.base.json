{
  "compilerOptions": {
    "target": "ES2023",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    // "ignoreDeprecations": "6.0",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "apps/web/src/*"
      ],
      "@web/*": [
        "apps/web/src/*"
      ],
      "@akfc/backend/*": [
        "packages/backend/src/*"
      ],
      "@akfc/contracts/*": [
        "packages/contracts/src/*"
      ],
    }
  },
  "include": [
    "next-env.d.ts",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "apps/web/src/cropper-elements.d.ts",
    "**/*.ts",
    "**/*.tsx",
    // ".next/types/**/*.ts",
    // ".next/dev/types/**/*.ts",
    "**/*.mts",
    "prisma/seed.js",
    "prisma.config.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist"
  ]
}
