generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
  engineType    = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String               @id @default(cuid())
  firstName             String?
  lastName              String?
  email                 String               @unique
  emailVerified         Boolean              @default(false)
  password              String
  birthDate             DateTime?
  phone                 String?
  image                 String?
  roleId                Int?
  memberSince           DateTime?
  isFirstLogin          Boolean              @default(true)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @default(now()) @updatedAt
  aboutMe               String?
  pseudo                String?
  avatar                String?
  Activities            Activity[]           @relation("UserActivities")
  comments              Comment[]
  Courses               Course[]             @relation("UserCourses")
  likes                 Like[]
  posts                 Post[]
  preferences           Preferences?
  sessions              Session[]
  Stage                 Stage[]              @relation("UserStages")
  role                  Role?                @relation(fields: [roleId], references: [id])
  auditLogsAsActor      AuditLog[]           @relation("AuditActor")
  auditLogsAsTargetUser AuditLog[]           @relation("AuditTargetUser")
  passwordResetTokens   PasswordResetToken[]
}

model Permission {
  id          Int               @id @default(autoincrement())
  name        String            @unique
  description String?
  roles       RolePermissions[]
}

model Role {
  id          Int               @id @default(autoincrement())
  name        String            @unique
  description String?
  permissions RolePermissions[]
  users       User[]
}

model RolePermissions {
  roleId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@id([roleId, permissionId])
}

model Preferences {
  id           Int     @id @default(autoincrement())
  displayEmail Boolean @default(false)
  displayPhone Boolean @default(false)
  darkMode     Boolean @default(true)
  userId       String  @unique
  description  String?
  user         User    @relation(fields: [userId], references: [id])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  role      String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/**
 * Audit Log (sécurité & support)
 * Objectif (minimal mais solide) :
 * - tracer les actions sensibles faites par un admin (ex: changement de rôle)
 * - conserver qui a fait quoi, sur qui, quand, + une meta JSON
 * Note :
 * - actorUserId/targetUserId sont nullable + onDelete:SetNull
 * pour conserver l'historique même si un compte est supprimé.
 */
model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  actorUserId String?
  actorEmail  String?

  action AuditAction

  targetUserId String?
  meta         Json?

  actor      User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser User? @relation("AuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action, createdAt])
}

enum AuditAction {
  USER_ROLE_CHANGED
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

model Course {
  id         Int      @id @default(autoincrement())
  beginTime  Int
  endTime    Int
  day        Day
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  content    Json
  label      String   @unique
  coachId    String
  requisites String[]
  coach      User     @relation("UserCourses", fields: [coachId], references: [id])
}

model Slot {
  id         Int       @id @default(autoincrement())
  beginTime  Int
  endTime    Int
  activityId Int?
  activity   Activity? @relation(fields: [activityId], references: [id])
}

model Activity {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  martialArt   String
  instructorId String
  origin       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  description  String?
  instructor   User     @relation("UserActivities", fields: [instructorId], references: [id])
  slots        Slot[]
}

model Category {
  id   Int    @id @default(autoincrement())
  type String @unique
}

model MartialArt {
  id          Int     @id @default(autoincrement())
  name        String
  style       String?
  origin      String?
  description String?
}

model Stage {
  id            Int      @id @default(autoincrement())
  date          DateTime
  beginTime     Int
  endTime       Int
  preRegistered String[]
  animatorId    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  label         String
  program       Json
  description   Json
  animator      User     @relation("UserStages", fields: [animatorId], references: [id])
}

model Post {
  id              Int       @id @default(autoincrement())
  title           String
  content         Json
  authorId        String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  publicationDate DateTime?
  comments        Comment[]
  likes           Like[]
  author          User      @relation(fields: [authorId], references: [id])
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   Json
  authorId  String
  articleId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  postId    Int?
  author    User     @relation(fields: [authorId], references: [id])
  post      Post?    @relation(fields: [postId], references: [id])
}

model Like {
  id     Int     @id @default(autoincrement())
  postId Int
  userId String
  like   Boolean @default(false)
  post   Post    @relation(fields: [postId], references: [id])
  user   User    @relation(fields: [userId], references: [id])
}

model CloudinaryFolder {
  id        String                 @id @default(cuid())
  appRoot   String
  fullPath  String
  status    CloudinaryFolderStatus
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@unique([appRoot, fullPath])
  @@index([appRoot])
  @@index([appRoot, status])
}

enum CloudinaryFolderStatus {
  pending
  published
  bin
}

/**
 * Corbeille (bin) : une entrée = un "root" jeté (folder ou file).
 * IMPORTANT (design validé) :
 * - Le storage Cloudinary réel est caché : `${appRoot}/bin/.trash/${id}/...`
 * - L'utilisateur voit seulement displayName + provenance (previousPath).
 * - Restore = toujours vers previousPath, collision => auto-rename du contenu restauré.
 * Méta comparaison :
 * - sizeBytes = somme des bytes du sous-arbre (si calculé)
 * - cloudinaryCreatedAt = max(created_at) du sous-arbre (choix "a")
 */
model TrashEntry {
  id      String           @id @default(uuid())
  appRoot String
  kind    TrashEntryKind
  status  TrashEntryStatus @default(IN_BIN)

  /**
   * Nom affiché dans la liste plate du bin
   * ex: "cours1" ou "image.png"
   */
  displayName String

  /**
   * Chemin d'origine complet (tooltip et cible de restore)
   * ex: "AKFC/pending/cours/cours1"
   */
  previousPath String

  /**
   * Chemin de stockage réel dans Cloudinary (caché)
   * ex:
   * - folder: "AKFC/bin/.trash/<uuid>/cours1"
   * - file:   "AKFC/bin/.trash/<uuid>/image.png" (ou public_id équivalent)
   */
  storageRoot String

  /**
   * Date de mise en corbeille (sert aussi au suffix de renommage en cas de collision au restore)
   */
  trashedAt DateTime @default(now())

  /**
   * Rempli lors du restore.
   * - restoredToPath == previousPath si pas de collision
   * - sinon, chemin renommé (suffix "bin <date>")
   */
  restoredAt     DateTime?
  restoredToPath String?

  /**
   * Si tu veux tracer la suppression définitive (audit).
   * Si tu préfères supprimer la ligne, tu peux omettre ce champ,
   * mais je recommande de le garder : ça aide énormément en debug/support.
   */
  deletedAt DateTime?

  /**
   * Métadonnées Cloudinary utiles en UI sans ouvrir la preview.
   * - Pour folder : agrégat du sous-arbre
   * - Pour file   : valeur du fichier
   */
  sizeBytes           BigInt?
  cloudinaryCreatedAt DateTime?

  @@index([appRoot])
  @@index([appRoot, status, trashedAt])
  @@index([appRoot, previousPath])
  @@index([appRoot, kind])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  tokenHash String @unique
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  requestIp String?
  userAgent String?

  @@index([userId, createdAt])
  @@index([expiresAt])
}

enum TrashEntryKind {
  folder
  file
}

enum TrashEntryStatus {
  IN_BIN
  RESTORED
  DELETED
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum WushuStyle {
  CHOY_LI_FUT
  TAI_CHI_CHUAN
  TANG_LANG_QUAN
  WING_CHUN
  CHANG_QUAN
  SHAOLIN_QUAN
  FAN_ZI_QUAN
  CHUO_JIAO
  BA_JI_QUAN
  HUNG_GAR
  LAU_GAR
  MOK_GAR
  XING_YI_QUAN
  BA_QUA_ZHANG
  HOU_QUAN
  SHE_QUAN
  YING_QUAN
  HU_QUAN
  HE_QUAN
  ZUI_QUAN
  SHUAI_JIAO
  QI_GONG
}
