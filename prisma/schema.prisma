generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
  engineType    = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTH
// ============================================================================

model User {
  id                    String               @id @default(cuid())
  firstName             String?
  lastName              String?
  email                 String               @unique
  emailVerified         Boolean              @default(false)
  password              String
  birthDate             DateTime?
  phone                 String?
  image                 String?
  roleId                Int?
  memberSince           DateTime?
  isFirstLogin          Boolean              @default(true)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @default(now()) @updatedAt
  aboutMe               String?
  pseudo                String?
  avatar                String?

  // --- Auth & profil
  role                  Role?                @relation(fields: [roleId], references: [id])
  preferences           Preferences?
  sessions              Session[]
  passwordResetTokens   PasswordResetToken[]

  // --- Audit
  auditLogsAsActor      AuditLog[]           @relation("AuditActor")
  auditLogsAsTargetUser AuditLog[]           @relation("AuditTargetUser")

  // --- Posts/comments/likes
  posts                 Post[]
  comments              Comment[]
  likes                 Like[]

  // --- Domaine métier (nouvelles relations)
  disciplinesAsInstructor   Discipline[]  @relation("DisciplineInstructor")
  coursesAsInstructor       Course[]      @relation("CourseInstructor")
  stagesAsPrimaryAnimator   Stage[]       @relation("StagePrimaryAnimator")
  stagesAsAnimator          Stage[]       @relation("StageAnimators")
  uploadedMediaAssets       MediaAsset[]  @relation("UserMediaUploads")
}

model Permission {
  id          Int               @id @default(autoincrement())
  name        String            @unique
  description String?
  roles       RolePermissions[]
}

model Role {
  id          Int               @id @default(autoincrement())
  name        String            @unique
  description String?
  permissions RolePermissions[]
  users       User[]
}

model RolePermissions {
  roleId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@id([roleId, permissionId])
}

model Preferences {
  id           Int     @id @default(autoincrement())
  displayEmail Boolean @default(false)
  displayPhone Boolean @default(false)
  darkMode     Boolean @default(true)
  userId       String  @unique
  description  String?
  user         User    @relation(fields: [userId], references: [id])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  tokenHash String @unique
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  requestIp String?
  userAgent String?

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

// ============================================================================
// AUDIT
// ============================================================================

/**
 * Audit Log (sécurité & support)
 * - Trace des actions sensibles faites par un admin (ex: changement de rôle)
 * - actorUserId/targetUserId nullable + onDelete:SetNull pour conserver l'historique
 */
model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  actorUserId String?
  actorEmail  String?

  action AuditAction

  targetUserId String?
  meta         Json?

  actor      User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser User? @relation("AuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action, createdAt])
}

enum AuditAction {
  USER_ROLE_CHANGED
}

// ============================================================================
// DOMAINE MÉTIER — Category → Discipline (modèle à 2 niveaux validé)
// ============================================================================

enum DisciplineType {
  MARTIAL_ART
  CALLIGRAPHY
}

enum Audience {
  KIDS
  TEENAGERS
  ADULTS
  ALL_AGES
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model Category {
  id   Int    @id @default(autoincrement())
  type String @unique // "Cours", "Stage", "Démo", ...

  disciplines Discipline[]
  mediaAssets MediaAsset[]
}

model Discipline {
  id             Int            @id @default(autoincrement())
  name           String                     // "Taï-chi", "Taolu multi-styles", "Tchoy-Lee-Fut", "Kali Escrima"
  type           DisciplineType             // MARTIAL_ART | CALLIGRAPHY
  family         String?                    // "Kung-fu Wushu" pour les pratiques chinoises, null sinon
  school         String?                    // "Chen" pour Taï-chi, sinon null
  classification String?                    // "interne (yin)" | "externe (yang)" | null
  origin         String?                    // "Chine du Sud", "Philippines", ...
  description    String?
  categoryId     Int                        // chaque discipline appartient à UNE catégorie
  instructorId   String                     // OBLIGATOIRE — référent de la discipline
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  category    Category     @relation(fields: [categoryId], references: [id])
  instructor  User         @relation("DisciplineInstructor", fields: [instructorId], references: [id])
  courses     Course[]
  stages      Stage[]
  mediaAssets MediaAsset[]

  @@unique([categoryId, name])
  @@index([categoryId])
  @@index([instructorId])
  @@index([type])
}

// ============================================================================
// OCCURRENCES
// ============================================================================

model Course {
  id           Int      @id @default(autoincrement())
  disciplineId Int                          // ex: Discipline "Tchoy-Lee-Fut"
  audience     Audience                     // KIDS | TEENAGERS | ADULTS | ALL_AGES
  day          Day
  beginTime    Int                          // minutes depuis minuit
  endTime      Int
  instructorId String?                      // si null, hérite de discipline.instructor
  requisites   String[]
  content      Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  discipline Discipline @relation(fields: [disciplineId], references: [id])
  instructor User?      @relation("CourseInstructor", fields: [instructorId], references: [id])

  @@unique([disciplineId, day, beginTime, audience])
  @@index([disciplineId])
  @@index([instructorId])
}

model Stage {
  id                Int      @id @default(autoincrement())
  disciplineId      Int                    // ex: Discipline "Tchoy-Lee-Fut" pour un stage de Tchoy-Lee-Fut
  label             String                 // "Stage d'été — initiation aux bâtons"
  audience          Audience
  description       Json
  program           Json
  preRegistered     String[]
  primaryAnimatorId String                 // OBLIGATOIRE — animateur principal (inclus dans `animators`)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  discipline      Discipline     @relation(fields: [disciplineId], references: [id])
  primaryAnimator User           @relation("StagePrimaryAnimator", fields: [primaryAnimatorId], references: [id])
  animators       User[]         @relation("StageAnimators")
  sessions        StageSession[]

  @@unique([disciplineId, label])
  @@index([disciplineId])
  @@index([primaryAnimatorId])
}

model StageSession {
  id        Int      @id @default(autoincrement())
  stageId   Int
  date      DateTime
  beginTime Int
  endTime   Int
  location  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stage Stage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@unique([stageId, date, beginTime])
  @@index([stageId])
  @@index([date])
}

// ============================================================================
// MEDIA
// ============================================================================

model MediaAsset {
  id                     String   @id @default(cuid())

  // --- Cloudinary
  publicId               String   @unique
  secureUrl              String
  resourceType           String
  mimeType               String
  format                 String?

  // --- Fichier
  originalFileName       String
  displayName            String?
  description            String?
  bytes                  Int
  width                  Int?
  height                 Int?
  duration               Float?

  // --- Métier
  appRoot                String
  status                 String                          // "pending" | "published" | ...
  categoryId             Int
  disciplineId           Int?                            // null si la Discipline est proposée mais pas encore créée
  proposedDisciplineName String?                         // nom proposé si disciplineId null
  eventDate              DateTime?

  // --- Provenance
  uploaderUserId         String
  uploadedAt             DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category   Category    @relation(fields: [categoryId], references: [id])
  discipline Discipline? @relation(fields: [disciplineId], references: [id])
  uploader   User        @relation("UserMediaUploads", fields: [uploaderUserId], references: [id])

  @@index([status])
  @@index([categoryId])
  @@index([disciplineId])
  @@index([uploaderUserId])
  @@index([uploadedAt])
}

// ============================================================================
// CLOUDINARY FOLDERS & TRASH (inchangé)
// ============================================================================

model CloudinaryFolder {
  id        String                 @id @default(cuid())
  appRoot   String
  fullPath  String
  status    CloudinaryFolderStatus
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@unique([appRoot, fullPath])
  @@index([appRoot])
  @@index([appRoot, status])
}

enum CloudinaryFolderStatus {
  pending
  published
  bin
}

/**
 * Corbeille (bin) : une entrée = un "root" jeté (folder ou file).
 */
model TrashEntry {
  id      String           @id @default(uuid())
  appRoot String
  kind    TrashEntryKind
  status  TrashEntryStatus @default(IN_BIN)

  displayName  String
  previousPath String
  storageRoot  String

  trashedAt DateTime @default(now())

  restoredAt     DateTime?
  restoredToPath String?

  deletedAt DateTime?

  sizeBytes           BigInt?
  cloudinaryCreatedAt DateTime?

  @@index([appRoot])
  @@index([appRoot, status, trashedAt])
  @@index([appRoot, previousPath])
  @@index([appRoot, kind])
}

enum TrashEntryKind {
  folder
  file
}

enum TrashEntryStatus {
  IN_BIN
  RESTORED
  DELETED
}

// ============================================================================
// CONTENU ÉDITORIAL (Posts/Comments/Likes — inchangé)
// ============================================================================

model Post {
  id              Int       @id @default(autoincrement())
  title           String
  content         Json
  authorId        String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  publicationDate DateTime?

  author   User      @relation(fields: [authorId], references: [id])
  comments Comment[]
  likes    Like[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   Json
  authorId  String
  articleId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  postId    Int?

  author User  @relation(fields: [authorId], references: [id])
  post   Post? @relation(fields: [postId], references: [id])
}

model Like {
  id     Int     @id @default(autoincrement())
  postId Int
  userId String
  like   Boolean @default(false)
  post   Post    @relation(fields: [postId], references: [id])
  user   User    @relation(fields: [userId], references: [id])
}
